    classDef data fill:#d9ecff,stroke:#4b79a8,stroke-width:2px,color:#1b3146;
    classDef model fill:#fbe0d2,stroke:#b66a3c,stroke-width:2px,color:#4a2410;
    classDef evidence fill:#e4f4df,stroke:#5e8f4b,stroke-width:2px,color:#21341a;
    classDef outcome fill:#f7e2f0,stroke:#9b4f86,stroke-width:2px,color:#45203b;
    classDef shadow fill:#efe7db,stroke:#c7b49d,stroke-width:1px,color:#7d6b55;

    S1["Stage 1"]:::stage --> S2["Stage 2"]:::stage --> S3["Stage 3"]:::stage --> S4["Stage 4"]:::stage

