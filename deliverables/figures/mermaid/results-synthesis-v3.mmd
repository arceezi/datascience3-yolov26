flowchart TD
    classDef input fill:#dbe8f7,stroke:#f7f9fc,stroke-width:4px,color:#223a64;
    classDef process fill:#f9f1d9,stroke:#f7f9fc,stroke-width:4px,color:#223a64;
    classDef evidence fill:#f8e4e4,stroke:#f7f9fc,stroke-width:4px,color:#223a64;
    classDef outcome fill:#e8e3f6,stroke:#f7f9fc,stroke-width:4px,color:#223a64;
    classDef support fill:#e4efe5,stroke:#f7f9fc,stroke-width:4px,color:#223a64;

    A["Aggregate metrics<br/>Model_C leads on<br/>mAP50 and F1"]:::evidence
    B["Class-wise pattern<br/>Jeepney strong,<br/>Tricycle weak"]:::evidence
    C["Confusion matrix<br/>shows stronger diagonal<br/>for better classes"]:::support
    D["Training dynamics<br/>support the selected<br/>comparative result"]:::support
    E["Model_C is the<br/>strongest tested<br/>configuration"]:::outcome
    F["Interpretive limits<br/>validation only and<br/>mixed hyperparameters"]:::process

    A --> E
    B --> E
    C -.-> E
    D -.-> E
    E --> F

    linkStyle 0,1,4 stroke:#8e8e8e,stroke-width:1.5px;
    linkStyle 2,3 stroke:#8e8e8e,stroke-width:1.5px,stroke-dasharray:5 5;
